{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/",
      "dest": "index.html"
    },
    {
      "src": "/login",
      "dest": "login.html"
    },
    {
      "src": "/dashboard",
      "dest": "dashboard.html"
    },
    {
      "src": "/pay",
      "dest": "pay.html"
    }
  ]
}